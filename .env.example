# ==== AWG WebUI configuration ====

# Admin credentials. Password will be hashed on first run if ADMIN_PASSWORD_HASH is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Secret key for signing session cookies. Generate with: openssl rand -hex 32
SECRET_KEY=please-change-me-to-a-long-random-string

# Bind address. Keep 127.0.0.1 so the panel is only reachable through an SSH tunnel:
#   ssh -L 8080:localhost:8080 root@server_ip
HOST=127.0.0.1
PORT=8080

# Path to the SQLite database file (inside the container).
DATABASE_URL=sqlite:////data/awgui.db

# Directory where AmneziaWG interface configs are written (host: /etc/amnezia/amneziawg).
AWG_CONFIG_DIR=/etc/amnezia/amneziawg

# Public endpoint advertised to clients (their config Endpoint = HOST:PORT).
# Leave empty to auto-detect the server's public IP at runtime.
PUBLIC_ENDPOINT=

# Default DNS pushed to clients.
DEFAULT_DNS=1.1.1.1, 1.0.0.1

# wg / awg binary names. Use "awg"/"awg-quick" for AmneziaWG, "wg"/"wg-quick" for plain WireGuard.
WG_BIN=awg
WG_QUICK_BIN=awg-quick

# Set to "1" to actually apply changes to the live system (run awg-quick, sync conf).
# Set to "0" for a dry-run / development mode where only the DB and config files are written.
APPLY_TO_SYSTEM=1
